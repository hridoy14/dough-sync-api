{
  "manifest_version": 3,
  "name": "dough-sync-api [TEST]",
  "version": "5.0.0",
  "description": "TESTING ONLY - content.js + templates test",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "cookies"
  ],
  "host_permissions": [
    "https://*.lovable.dev/*",
    "https://api.lovable.dev/*",
    "https://lovable.dev/*",
    "https://bcrzdgkyydfutrbcbbrt.supabase.co/*",
    "https://dough-sync-api.vercel.app/*",
    "https://*.vercel.app/*"
  ],
  "action": {
    "default_title": "dough-sync-api [TEST]",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
  {
    "matches": [
      "https://*.lovable.dev/*",
      "https://lovable.dev/*"
    ],
    "js": [
      "pageHook.js"
    ],
    "run_at": "document_start",
    "world": "MAIN"
  },
  {
    "matches": [
      "https://*.lovable.dev/*",
      "https://lovable.dev/*",
      "https://api.lovable.dev/*"
    ],
    "js": [
      "i18n.js",
      "hwFingerprint.js",
      "license-fix.js",
      "content-templates.js",
      "content.js"
    ],
    "css": [
      "floating.css"
    ],
    "run_at": "document_idle"
  }
],
  "web_accessible_resources": [
  {
    "resources": [
      "pageHook.js",
      "license-fix.js",
      "assets/logo-master-lovable.png",
      "assets/logo-master-lovable-square.png",
      "assets/icon16.png",
      "assets/icon32.png",
      "assets/icon48.png",
      "assets/icon128.png"
    ],
    "matches": [
      "https://*.lovable.dev/*",
      "https://lovable.dev/*"
    ]
  }
],
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
