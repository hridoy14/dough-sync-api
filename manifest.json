{
  "manifest_version": 3,
  "name": "dough-sync-api",
  "version": "5.00",
  "description": "Powered by dough-sync-api",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "sidePanel",
    "cookies"
  ],
  "host_permissions": [
    "https://*.lovable.dev/*",
    "https://api.lovable.dev/*",
    "https://lovable.dev/*",
    "https://lovable-api.com/*",
    "https://bcrzdgkyydfutrbcbbrt.supabase.co/*",
    "https://dough-sync-api.vercel.app/*",
    "https://*.vercel.app/*"
  ],
  "action": {
    "default_title": "dough-sync-api",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.lovable.dev/*",
        "https://lovable.dev/*"
      ],
      "js": [
        "pageHook.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://*.lovable.dev/*",
        "https://lovable.dev/*",
        "https://api.lovable.dev/*"
      ],
      "js": [
        "jszip.min.js",
        "hwFingerprint.js",
        "sounds.js",
        "i18n.js",
        "content-templates.js",
        "content.js",
        "license-fix.js"
      ],
      "css": [
        "floating.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "pageHook.js",
        "sounds/error-payment.mp3",
        "sounds/error-ratelimit.mp3",
        "sounds/error-token.mp3",
        "assets/logo-master-lovable.png",
        "assets/logo-master-lovable-square.png",
        "assets/icon16.png",
        "assets/icon32.png",
        "assets/icon48.png",
        "assets/icon128.png",
        "license-fix.js"
      ],
      "matches": [
        "https://*.lovable.dev/*",
        "https://lovable.dev/*"
      ]
    }
  ],
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
